{
  "name": "select-theme",
  "displayName": "Select Theme",
  "description": "Instantly browse, preview, and switch between all your installed VS Code themes using a convenient, quick-access dropdown menu.",
  "version": "1.2.0",
  "publisher": "SelectTheme",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "select-theme.selectTheme",
        "title": "Select Theme",
        "icon": "$(symbol-color)"
      },
      {
        "command": "select-theme.standardTheme",
        "title": "Toggle Mode (Light/Dark)",
        "icon": "$(color-mode)"
      },
      {
        "command": "select-theme.toggleAutoDetect",
        "title": "Toggle Auto-Detect Color Scheme",
        "icon": "$(sync)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "select-theme.toggleAutoDetect",
          "group": "navigation@1"
        },
        {
          "command": "select-theme.standardTheme",
          "group": "navigation@2"
        },
        {
          "command": "select-theme.selectTheme",
          "group": "navigation@3"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mosesarulvin/vs-code-select-theme-extension"
  }
}
