{
  "name": "select-theme",
  "displayName": "Select Theme",
  "description": "Instantly browse, preview, and switch between all your installed VS Code themes using a convenient, quick-access dropdown menu.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [{
      "command": "select-theme.selectTheme",
      "title": "Select Theme",
      "icon": "$(symbol-color)"
    }],
    "menus": {
      "editor/title": [{
        "command": "select-theme.selectTheme",
        "group": "navigation"
      }]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
